@startuml Authentification
title Diagramme d'activité — S'authentifier (Login / SignUp)

start

if (L'utilisateur a déjà un compte ?) then (Oui — Login)

  :Saisir email et mot de passe;

  :Vérifier les champs
  (LoginGUI.verifyInput());

  if (Champs valides ?) then (non)
    :Afficher erreur de saisie;
    stop
  else (oui)
  endif

  :Appeler AuthentificationController
  .login(email, password);

  :Vérifier existence du compte
  (AccountRepository.exists());

  if (Compte existe ?) then (non)
    :Afficher erreur
    "Compte inexistant";
    stop
  else (oui)
  endif

  :Vérifier identifiants
  (verifyCredentials());

  :Comparer le mot de passe
  avec le hash en base;

  if (Identifiants valides ?) then (non)
    :Afficher erreur
    "Email ou mot de passe incorrect";
    stop
  else (oui)
  endif

  if (Rôle de l'utilisateur ?) then (Admin)
    :Rediriger vers
    AdminDashboardGUI;
  else (Développeur / Reviewer)
    :Rediriger vers
    DashboardGUI;
  endif

else (Non — SignUp)

  :Saisir les informations du profil
  (nom, prénom, pseudo);

  :Saisir l'adresse email;

  :Vérifier les champs
  (SignUpGUI.verifyInput());

  if (Champs valides ?) then (non)
    :Afficher erreur de saisie;
    stop
  else (oui)
  endif

  :Vérifier si l'email existe déjà
  (AccountRepository.findByEmail());

  if (Email déjà utilisé ?) then (oui)
    :Afficher erreur
    "Email déjà enregistré";
    stop
  else (non)
  endif

  :Rediriger vers la plateforme
  externe pour OAuth;

  repeat

    :Choisir une plateforme
    (GitHub / GitLab / Bitbucket);

    :Rediriger vers l'authentification
    OAuth de la plateforme
    (SignUpGUI.externalAuthRedirect());

    :La plateforme externe
    traite l'authentification;

    if (Authentification OAuth réussie ?) then (non)
      :Afficher erreur
      "Échec de connexion externe";

      if (Réessayer ?) then (oui)
      else (non)
        stop
      endif

    else (oui)
      :Lier le compte externe
      (AuthentificationController
      .linkExternalAccount());

      :Sauvegarder le lien
      (DeveloperAccountRepository
      .addExternalAccountLink());
    endif

  repeat while (Ajouter un autre\ncompte externe ?) is (oui)
  -> non;

  :Créer le compte DeveloperAccount
  (AuthentificationController.signUp());

  :Sauvegarder en base
  (DeveloperAccountRepository.create());

  :Synchroniser les PRs depuis
  les comptes liés
  (SynchronisationController
  .synchronizePRs());

  :Rediriger vers DashboardGUI;

endif

stop

@enduml
